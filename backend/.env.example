MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/student-mgmt?retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=replace_with_a_long_random_secret
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Email via Brevo API (recommended)
# 1. Sign up at https://www.brevo.com
# 2. Go to API & Apps > API Keys
# 3. Create or copy your API key
# 4. Paste it below with your sender email
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your-verified-sender@example.com

# ── OR Email via Resend (alternative)
# 1. Sign up at https://resend.com
# 2. Create an API key
# 3. Paste the API key below
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── OR Email via Gmail (alternative)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=yourgmail@gmail.com
# EMAIL_PASS=your_app_password
